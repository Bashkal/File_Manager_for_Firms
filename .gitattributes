# Auto detect text files and normalize line endings to LF
* text=auto

# C# files
*.cs text eol=crlf diff=csharp
*.csproj text eol=crlf merge=union
*.sln text eol=crlf merge=union

# Razor views
*.cshtml text eol=crlf
*.vbhtml text eol=crlf

# JSON, YAML, XML files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.exe binary
*.dll binary
*.pdb binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.7z binary
*.db binary
*.mdb binary
